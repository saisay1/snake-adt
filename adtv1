-- ============================================================
-- FOLLOW LOOP (bringwithloop)
-- ============================================================
local DISTANCE_THRESHOLD = 350
local FOLLOW_OFFSET = Vector3.new(0, 15, 250)
local FOLLOW_SPEED = 0.08
local following = false
local processedModels = {}
local followModels = {}

local function setPrimaryPart(model)
	if not model:IsA("Model") then return end
	if model.PrimaryPart then return end
	for _, obj in ipairs(model:GetDescendants()) do
		if obj:IsA("BasePart") then model.PrimaryPart = obj break end
	end
end

local function trackModel(model)
	if not following then return end
	if not model:IsA("Model") then return end
	local lname = string.lower(model.Name)
	if not validNameSet[lname] then return end
	if processedModels[model] or followModels[model] then return end
	setPrimaryPart(model)
	if model.PrimaryPart then processedModels[model] = true end
end

local function checkAndTeleport()
	for model in pairs(processedModels) do
		if model and model.PrimaryPart then
			local dist = (model.PrimaryPart.Position - HumanoidRootPart.Position).Magnitude
			if dist >= DISTANCE_THRESHOLD then
				local targetCFrame = HumanoidRootPart.CFrame + FOLLOW_OFFSET
				for _, part in ipairs(model:GetDescendants()) do
					if part:IsA("BasePart") then part.Anchored = true end
				end
				model:SetPrimaryPartCFrame(targetCFrame)
				followModels[model] = true
				processedModels[model] = nil
			end
		end
	end
end

local function moveFollowModels()
	for model in pairs(followModels) do
		if model and model.PrimaryPart then
			local cur = model.PrimaryPart.CFrame
			local tgt = HumanoidRootPart.CFrame + FOLLOW_OFFSET
			model:SetPrimaryPartCFrame(cur:Lerp(tgt, FOLLOW_SPEED))
		else
			followModels[model] = nil
		end
	end
end

local function dropAllModels()
	following = false
	local idx = 0
	for model in pairs(followModels) do
		if model and model.PrimaryPart then
			local angle = math.rad(idx * 30)
			local offset = Vector3.new(math.cos(angle)*250, 15, math.sin(angle)*250)
			model:SetPrimaryPartCFrame(HumanoidRootPart.CFrame + offset)
			idx += 1
		end
	end
	processedModels = {}
	followModels = {}
end

local function toggleFollow()
	if following then
		dropAllModels()
	else
		following = true
		for _, model in ipairs(workspace:GetDescendants()) do trackModel(model) end
	end
end

Workspace.DescendantAdded:Connect(trackModel)

RunService.Heartbeat:Connect(function()
	if following then checkAndTeleport(); moveFollowModels() end
end)


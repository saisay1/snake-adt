	toggleFollow()
	if following then
		bringwithloop.Text = "⟳ Following..."
		TweenService:Create(bringwithloop, TweenInfo.new(0.15), {BackgroundColor3 = C.success}):Play()
	else
		bringwithloop.Text = "Follow Loop"

local function makeBtn(parent, text, x, y, w, h, color)
	w = w or 0.13
	h = h or 0.09
	color = color or C.accentDim
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.fromScale(w, h)
	btn.Position = UDim2.fromScale(x, y)
	btn.BackgroundColor3 = color
	btn.Text = text
	btn.TextColor3 = C.text
	btn.TextScaled = true
	btn.Font = Enum.Font.Gotham
	btn.Parent = parent
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
	addStroke(btn, C.border, 1)
	applyHover(btn, color, C.cardHover)
	return btn
end


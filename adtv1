-- ============================================================
-- GET ALL PICKUPABLE OBJECTS
-- Берём ВСЁ из workspace КРОМЕ:
--   - Terrain
--   - объектов внутри "Map" (постройки, дороги)
--   - объектов внутри "RoadPrefabs"
-- Берём ВСЁ из "BuildingItemStorage" (предметы которые можно взять)
-- Персонажи игроков тоже пропускаются.
-- ============================================================

local function getPlayerModels()
	local set = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Character then set[p.Character] = true end
	end
	return set
end

local function GetAllObjects()
	local playerModels = getPlayerModels()
	local collected = {}
	local seen = {}

	-- НПС имеют Humanoid внутри — пропускаем их
	local function hasHumanoid(obj)
		return obj:FindFirstChildWhichIsA("Humanoid", true) ~= nil
	end

	-- Забираем все Model/Tool из контейнера с primaryPart
	local function collectFromContainer(container)
		if not container then return end
		for _, obj in ipairs(container:GetDescendants()) do
			if (obj:IsA("Model") or obj:IsA("Tool")) and not seen[obj] and not playerModels[obj] then
				if hasHumanoid(obj) then continue end -- пропускаем НПС
				-- Найдём primary part
				local pp = obj.PrimaryPart
				if not pp then
					pp = obj:FindFirstChildWhichIsA("BasePart", true)
					if pp then obj.PrimaryPart = pp end
				end
				if pp then
					seen[obj] = true
					table.insert(collected, obj)
				end
			end
		end
	end

	-- Список имён папок которые надо полностью ПРОПУСТИТЬ
	local skipFolders = {}
	local mapFolder      = workspace:FindFirstChild("Map")
	local roadFolder     = workspace:FindFirstChild("RoadPrefabs")
	if mapFolder  then skipFolders[mapFolder]  = true end
	if roadFolder then skipFolders[roadFolder] = true end

	-- Также пропускаем персонажей
	for model in pairs(playerModels) do
		skipFolders[model] = true
	end

	-- Сначала берём всё из BuildingItemStorage отдельно
	local storage = workspace:FindFirstChild("BuildingItemStorage")
	collectFromContainer(storage)
	if storage then skipFolders[storage] = true end -- чтобы не дублировать ниже

	-- Теперь сканируем остальной workspace
	for _, child in ipairs(workspace:GetChildren()) do
		if child:IsA("Terrain") then continue end
		if child == Camera then continue end
		if skipFolders[child] then continue end

		-- Если это Model/Tool напрямую в workspace
		if (child:IsA("Model") or child:IsA("Tool")) and not playerModels[child] then
			local pp = child.PrimaryPart
			if not pp then
				pp = child:FindFirstChildWhichIsA("BasePart", true)
				if pp then child.PrimaryPart = pp end
			end
			if pp and not seen[child] then
				seen[child] = true
				table.insert(collected, child)
			end
		end

		-- Папки/контейнеры — сканируем содержимое
		if child:IsA("Folder") or child:IsA("Model") then
			collectFromContainer(child)
		end
	end

	return collected
end

local function bringObjectToPlayer(obj)
	-- Позиция сзади игрока: берём направление взгляда и инвертируем
	-- LookVector смотрит вперёд, -LookVector = назад
	local behindOffset = -HumanoidRootPart.CFrame.LookVector * 6
	-- Небольшой разброс по бокам чтобы вещи не складывались в одну точку
	local sideOffset = HumanoidRootPart.CFrame.RightVector * math.random(-3, 3)
	local targetCFrame = CFrame.new(
		HumanoidRootPart.Position + behindOffset + sideOffset + Vector3.new(0, 0.5, 0)
	)

	if obj:IsA("Model") then
		local pp = obj.PrimaryPart
		if pp then
			pp.Anchored = false
			obj:SetPrimaryPartCFrame(targetCFrame)
		end
	elseif obj:IsA("BasePart") then
		obj.Anchored = false
		obj.CFrame = targetCFrame
	end
end


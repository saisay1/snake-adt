local function applySpeed(val)
	local num = tonumber(val)
	if not num then
		speedStatus.Text = "⚠ Введи число!"
		speedStatus.TextColor3 = C.danger
		return
	end
	num = math.clamp(num, 0, 500)
	local char = plr.Character or plr.CharacterAdded:Wait()
	local hum = char:FindFirstChildWhichIsA("Humanoid")
	if hum then
		hum.WalkSpeed = num
		speedBox.Text = tostring(num)
		speedStatus.Text = "✔ Скорость: " .. num
		speedStatus.TextColor3 = C.success
		TweenService:Create(speedStatus, TweenInfo.new(2), {TextColor3 = C.textDim}):Play()
	else
		speedStatus.Text = "⚠ Humanoid не найден"
		speedStatus.TextColor3 = C.danger
	end
end

